{
  "expo": {
    "name": "AgriGov",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agrigov.transporter"
    },
    "android": {
      "package": "com.agrigov.transporter",
      "usesCleartextTraffic": true
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow camera access"
        }
      ]
    ]
  }
}
